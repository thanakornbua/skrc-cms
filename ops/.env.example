# Copy to ops/.env for `docker compose up`. Never commit the real file.
# Mirrors docs/spec/ENV.md — placeholders only.

AWS_REGION=ap-southeast-7
# Prefix all Cognito/Lambda/IAM/API Gateway resources; use a distinct value for staging.
RESOURCE_PREFIX=robo-compet
DYNAMO_TABLE=robo-compet
COGNITO_USER_POOL_ID=ap-southeast-7_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
CORS_ORIGIN=https://competitive.skrc.suankularb.space
API_DOMAIN=api.suankularb.space
EMAIL_REGION=ap-southeast-1
EMAIL_DOMAIN=suankularb.space
EMAIL_FROM=skrc@suankularb.space
EMAIL_REPLY_TO=thanakorn@thanakorn.site
PORTAL_URL=https://competitive.skrc.suankularb.space/portal
CONTACT_EMAIL=thanakorn@thanakorn.site
EMAIL_ENABLED=false
PORT=3000
DEVICE_KEYS={"esp32-lane1":"<random-key>","esp32-lane2":"<random-key>"}
# One lane at launch (operator decision); expand by editing this array, e.g. [{"laneId":"1","deviceId":"esp32-lane1"}]
LANES=["1"]

# Laptop serial bridge fallback (never place device keys on the serial firmware).
SERIAL_API_URL=https://api.suankularb.space
SERIAL_SPOOL_DIR=.serial-spool
SERIAL_LANES={"esp32-lane1":"1","esp32-lane2":"2"}
