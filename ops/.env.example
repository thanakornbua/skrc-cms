# Copy to ops/.env for `docker compose up`. Never commit the real file.
# Mirrors docs/spec/ENV.md — placeholders only.

AWS_REGION=ap-southeast-7
DYNAMO_TABLE=robo-compet
COGNITO_USER_POOL_ID=ap-southeast-7_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
CORS_ORIGIN=https://competitive.skrc.suankularb.space
PORT=3000
DEVICE_KEYS={"esp32-lane1":"<random-key>","esp32-lane2":"<random-key>"}
# One lane at launch (operator decision); expand by editing this array, e.g. [{"laneId":"1","deviceId":"esp32-lane1"}]
LANES=["1"]
