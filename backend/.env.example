# Copy to backend/.env for local (non-Docker) development. Never commit the real file.
# Mirrors docs/spec/ENV.md — placeholders only.

AWS_REGION=ap-southeast-7
RESOURCE_PREFIX=robo-compet
DYNAMO_TABLE=robo-compet
COGNITO_USER_POOL_ID=ap-southeast-7_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
CORS_ORIGIN=http://localhost:5173
CLOUDFLARE_EMAIL_TOKEN_SECRET_ID=/robo-compet/staging/cloudflare-email-token
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@skrc.suankularb.space
EMAIL_REPLY_TO=skrc@skrc.suankularb.space
PORTAL_URL=https://competitive.skrc.suankularb.space/portal
CONTACT_EMAIL=skrc@skrc.suankularb.space
EMAIL_ENABLED=false
PORT=3000
DEVICE_KEYS={"esp32-lane1":"<random-key>","esp32-lane2":"<random-key>"}
# One lane at launch (operator decision); expand by editing this array, e.g. [{"laneId":"1","deviceId":"esp32-lane1"}]
LANES=["1"]
